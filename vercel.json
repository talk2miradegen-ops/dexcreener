{
  "rewrites": [
    {
      "source": "/vote/:ca",
      "destination": "/api/vote?ca=:ca"
    },
    {
      "source": "/api/og-image/:ca.png",
      "destination": "/api/og-image?ca=:ca"
    },
    {
      "source": "/secureproxy",
      "destination": "/api/secureproxy"
    },
    {
      "source": "/solanaproxy",
      "destination": "/api/solanaproxy"
    },
    {
      "source": "/(.*)",
      "destination": "/index.html"
    }
  ]
}
